					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "Date",
					"value": {
						"value": "@activity('Lkp_Run_Date').output.firstRow.RUN_DATE",
						"type": "Expression"
					}
				}
			},
			{
				"name": "UpdFlowStatus",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Flow_Data_Prepare",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"additionalColumns": [
							{
								"name": "DATE",
								"value": {
									"value": "@formatDateTime(adddays(activity('Lkp_Run_Date').output.firstRow.RUN_DATE,1),'yyyy-MM-dd')",
									"type": "Expression"
								}
							}
						],
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
