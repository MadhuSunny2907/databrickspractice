						"activity": "V_Date",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataflow": {
						"referenceName": "Flow_Prepare_Data",
						"type": "DataFlowReference",
						"parameters": {
							"Date": {
								"value": "'@{variables('Date')}'",
								"type": "Expression"
							}
						},
						"datasetParameters": {
